                    {
                        "title": "Specialist Night Experience",
                        "body": "Our night workers understand overnight care, from settling routines and regular checks to responding calmly when a resident needs help."
                    },
                    {
                        "title": "Rapid Cover",
                        "body": "When a night shift falls through, we work quickly to place a suitable, vetted worker from our Greater London pool."
                    },
                    {
                        "title": "Borough-Wide Availability",
                        "body": "Our workers are based across Greater London, which helps us reach your service and provide staff familiar with local care settings."
                    },
                    {
                        "title": "Fully Vetted Night Staff",
                        "body": "Every night worker is DBS-checked, right-to-work verified, and referenced before placement."
                    },
                    {
                        "title": "Flexible Options",
                        "body": "Book a single night, a block of nights, or ongoing overnight cover while you recruit, with arrangements that flex around your rota."
                    },
                    {
                        "title": "Reduced Disruption",
                        "body": "Consistent, prepared workers keep handovers simple and help residents feel settled through the night."
                    }
                ]
