        {
            "type": "faq",
            "fields": {
                "items": [
                    {
                        "q": "Do you supply staff for night shifts only?",
                        "a": "Yes. We supply night-shift care workers across Greater London, whether you need cover for a single night or a longer run of shifts."
                    },
                    {
                        "q": "Which roles can work nights?",
                        "a": "We supply healthcare assistants, support workers, and specialist night staff for overnight cover, matched to the needs of your setting."
                    },
                    {
                        "q": "Are night workers vetted to the same standard?",
                        "a": "They are. Every night worker is DBS-checked, right-to-work verified, and referenced before placement."
                    },
                    {
                        "q": "Can you provide night cover at short notice?",
                        "a": "We prioritise urgent requests and work to place a suitable night worker as quickly as we can, and we will be clear about timing."
                    },
                    {
                        "q": "What settings do you cover for night shifts?",
                        "a": "We provide night-shift staff for care homes, supported living services, and private residences across Greater London."
                    }
                ]
            },
