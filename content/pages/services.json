        {
            "type": "faq",
            "fields": {
                "items": [
                    {
                        "q": "What types of staff can you supply?",
                        "a": "We supply healthcare assistants, support workers and healthcare cleaners, along with emergency, night-shift, temporary and live-in cover."
                    },
                    {
                        "q": "How do we arrange cover?",
                        "a": "Once you share your requirements, our coordination team matches suitable, vetted workers to your shifts and confirms the details with you."
                    },
                    {
                        "q": "How are workers vetted?",
                        "a": "All workers complete enhanced DBS checks, right-to-work verification and reference checks, plus mandatory training in safeguarding and infection control."
                    },
                    {
                        "q": "Which areas do you cover?",
                        "a": "We cover providers across Greater London, including central, north, south, east and west London boroughs."
                    }
                ]
            },
