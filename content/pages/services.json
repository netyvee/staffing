                    {
                        "title": "Healthcare Assistants",
                        "body": "Vetted healthcare assistants for care homes, nursing homes and supported living, available for planned shifts and short-notice cover."
                    },
                    {
                        "title": "Support Workers",
                        "body": "Support workers who assist with personal care, mobility and daily living across residential, supported-living and specialist services."
                    },
                    {
                        "title": "Healthcare Cleaners",
                        "body": "Healthcare cleaners trained to NHS cleaning standards for care homes, clinics and supported living, helping you maintain a safe environment."
                    },
                    {
                        "title": "Emergency Care Cover",
                        "body": "Reliable short-notice cover when a shift falls through, so your service stays safely staffed."
                    },
                    {
                        "title": "Night-Shift Care Staff",
                        "body": "Experienced overnight workers, from waking nights to sleep-in support, to keep your service settled after hours."
                    },
                    {
                        "title": "Temporary Care Staff",
                        "body": "Flexible cover for single shifts, block bookings and longer assignments while you manage absence or recruitment."
                    },
                    {
                        "title": "Live-in Carers",
                        "body": "Live-in carers providing continuous one-to-one support in a person's own home across Greater London."
                    }
